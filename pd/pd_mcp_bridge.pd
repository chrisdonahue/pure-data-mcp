#N canvas 116 93 1008 704 12;
#X text 28 22 Pd MCP bridge for vanilla Pure Data.;
#X text 28 50 Open this patch before using the MCP server. The server sends FUDI messages over UDP port 5000.;
#X text 28 76 All agent-managed objects live inside the "target" subpatch so the server can safely clear and rebuild it.;
#X obj 34 149 netreceive -u 5000;
#X obj 34 184 route canvas send dsp;
#X obj 34 220 s pd-mcp-canvas;
#N canvas 338 172 466 320 dynamic-send 0;
#X obj 32 27 inlet;
#X obj 32 61 list split 1;
#X obj 181 98 list store;
#X obj 32 96 t b s;
#X obj 123 131 symbol;
#X msg 123 165 symbol \$1;
#X obj 181 132 list trim;
#X obj 181 211 send;
#X connect 0 0 1 0;
#X connect 1 0 3 0;
#X connect 1 1 2 1;
#X connect 2 0 6 0;
#X connect 3 0 2 0;
#X connect 3 1 4 0;
#X connect 4 0 5 0;
#X connect 5 0 7 1;
#X connect 6 0 7 0;
#X restore 193 220 pd dynamic-send;
#X obj 352 220 list prepend dsp;
#X obj 352 255 s pd;
#X text 620 27 Managed patch lives here:;
#N canvas 566 152 856 585 target 0;
#X obj 24 22 namecanvas pd-mcp-canvas;
#X text 24 57 The Python MCP server sends dynamic patching messages here.;
#X text 24 82 You can unlock and inspect this subpatch \, but manual edits may be overwritten on the next sync.;
#X restore 621 53 pd target;
#X connect 3 0 4 0;
#X connect 4 0 5 0;
#X connect 4 1 6 0;
#X connect 4 2 7 0;
#X connect 7 0 8 0;
